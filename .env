PERSONA_CHAT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434   # optional if you use the default
OLLAMA_CHAT_MODEL=gpt-oss:120b-cloud                # any model you have installed in Ollama
# Ollama does not support remote embeddings, so the code falls back to a dummy score.

PERSONA_CHAT_PROVIDER=openai
OPENAI_API_KEY={OPENAI_API_KEY}   # your OpenAI secret key
OPENAI_CHAT_MODEL=gpt-4.1  # or any model you have access to
OPENAI_EMBEDDING_MODEL=text-embedding-3-small